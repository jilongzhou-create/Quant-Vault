# ============================================================
# SaaS Platform Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# FRED API Key (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# FMP API Key (https://financialmodelingprep.com/developer/docs/)
FMP_API_KEY=your_fmp_api_key_here

# Proxy mode: direct or proxy
PROXY_MODE=direct

# ============================================================
# SaaS Platform - Supabase (https://supabase.com)
# ============================================================
SAAS_SUPABASE_URL=https://xxxxx.supabase.co
SAAS_SUPABASE_KEY=your_supabase_anon_key_here

# SaaS encryption master key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_KEY=your_fernet_master_key_here
